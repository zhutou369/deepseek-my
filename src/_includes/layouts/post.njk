---
layout: layouts/base.njk
---

<style>
  .post-layout-grid { display: grid; grid-template-columns: 18fr 7fr; gap: 40px; margin-top: 40px; }
  @media (max-width: 900px) { .post-layout-grid { grid-template-columns: 1fr; } }
  
  .post-article { background: #fff; }
  .post-h1 { font-size: 34px; line-height: 1.3; color: var(--text-dark); margin: 0 0 20px 0; }
  .post-meta { font-size: 14px; color: #94a3b8; padding-bottom: 20px; border-bottom: 1px solid #f1f5f9; margin-bottom: 30px; }
  
  .markdown-body { font-size: 17px; line-height: 1.9; color: #334155; }
  .markdown-body h2 { font-size: 24px; color: var(--main-indigo); border-left: 5px solid var(--main-indigo); padding-left: 15px; margin: 40px 0 20px; }
  .markdown-body img { max-width: 100%; border-radius: 10px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); margin: 25px 0; }

  /* 側邊欄最新更新 */
  .sidebar-box { border: 1px solid #f1f5f9; background: var(--soft-bg); padding: 25px; border-radius: 12px; position: sticky; top: 100px; }
  .sidebar-box h3 { font-size: 17px; margin-top: 0; color: var(--text-dark); }
  .sidebar-ul { list-style: none; padding: 0; margin: 15px 0 0 0; }
  .sidebar-ul li { margin-bottom: 15px; font-size: 14px; }
  .sidebar-ul a { text-decoration: none; color: #4b5563; transition: 0.2s; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sidebar-ul a:hover { color: var(--main-indigo); }

  /* 上一篇下一篇導航 */
  .post-nav-footer { margin-top: 60px; padding-top: 30px; border-top: 1px solid #eee; display: flex; justify-content: space-between; gap: 20px; }
  .nav-link-box { flex: 1; padding: 15px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; text-decoration: none; transition: 0.3s; }
  .nav-link-box:hover { border-color: var(--main-indigo); background: var(--soft-bg); }
  .nav-label { font-size: 12px; color: #94a3b8; display: block; margin-bottom: 5px; }
  .nav-title { font-size: 14px; color: var(--text-dark); font-weight: 600; display: block; }
</style>

<div class="container post-layout-grid">
  <article class="post-article">
    {# 🌟 唯一 H1 文章標題 #}
    <h1 class="post-h1">{{ title }}</h1>
    <div class="post-meta">
      <span>發佈日期：{{ date | dateFilter }}</span> | 
      <span>節點歸屬：DeepSeek 一號核心樞紐</span>
    </div>

    <section class="markdown-body">
      {{ content | safe }}
    </section>

    {# 上一篇 / 下一篇 內鏈導航 #}
    <div class="post-nav-footer">
      {% set previousPost = collections.posts | getPreviousCollectionItem(page) %}
      {% set nextPost = collections.posts | getNextCollectionItem(page) %}
      
      <div style="width:48%;">
        {% if previousPost %}
          <a href="{{ previousPost.url }}" class="nav-link-box">
            <span class="nav-label">⬅️ PREV 上一篇技術指南</span>
            <span class="nav-title">{{ previousPost.data.title }}</span>
          </a>
        {% endif %}
      </div>
      <div style="width:48%; text-align:right;">
        {% if nextPost %}
          <a href="{{ nextPost.url }}" class="nav-link-box">
            <span class="nav-label">NEXT 下一篇技術指南 ➡️</span>
            <span class="nav-title">{{ nextPost.data.title }}</span>
          </a>
        {% endif %}
      </div>
    </div>
  </article>

  <aside class="post-sidebar">
    <div class="sidebar-box">
      <h3>📈 5篇最新技術更新</h3>
      <ul class="sidebar-ul">
        {% for item in collections.posts | limit(5) %}
          <li><a href="{{ item.url }}" title="{{ item.data.title }}">{{ item.data.title }}</a></li>
        {% endfor %}
      </ul>
      <div style="margin-top: 25px; font-size: 13px; color: #94a3b8; line-height: 1.5;">
        本站內容專為全球華人開發者優化，代碼經過本地集群環境真實測試，確保百分之百可用。
      </div>
    </div>
  </aside>
</div>