---
layout: layouts/base.njk
---
<style>
  .post-layout-grid { display: grid; grid-template-columns: 17fr 7fr; gap: 40px; }
  @media (max-width: 900px) { .post-layout-grid { grid-template-columns: 1fr; } }
  
  .post-content-header h1 { font-size: 30px; color: #111; margin-top: 0; margin-bottom: 15px; line-height: 1.4; }
  .post-content-meta { font-size: 14px; color: #777; display: flex; gap: 15px; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
  .post-body-markdown { font-size: 16px; color: #333; line-height: 1.8; text-align: justify; }
  .post-body-markdown h2 { font-size: 22px; color: #0066cc; margin-top: 35px; border-left: 4px solid #0066cc; padding-left: 12px; }
  .post-body-markdown img { max-width: 100% !important; height: auto !important; display: block; margin: 20px auto; border-radius: 6px; }

  .sidebar-panel { border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; background: #fff; }
  .sidebar-panel h3 { margin-top: 0; font-size: 16px; border-left: 4px solid #0066cc; padding-left: 10px; margin-bottom: 15px; }
  .sidebar-list { list-style: none; padding: 0; margin: 0; }
  .sidebar-list li { padding: 8px 0; border-bottom: 1px dashed #eee; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
</style>

<div class="post-layout-grid">
  <article class="post-content-wrapper">
    <header class="post-content-header">
      {# 智能保險鎖：如果正文內不含 h1 標籤，外殼渲染唯一的 h1 文章標題 #}
      {% if "<h1" not in content %}
        <h1>{{ title }}</h1>
      {% endif %}
      <div class="post-content-meta">
        <span>發布日期：{{ date | dateFilter }}</span>
        <span>分類：DeepSeek 核心技術專題</span>
      </div>
    </header>

    <section class="post-body-markdown">
      {{ content | safe }}
    </section>
    
    <div class="post-pagination-nav" style="margin: 40px 0 20px 0; padding: 20px; background: #f9f9f9; border-radius: 6px; border-left: 4px solid #0066cc;">
      <ul style="list-style: none; padding: 0; margin: 0; line-height: 2;">
        {%- set previousPost = collections.posts | getPreviousCollectionItem(page) %}
        {%- set nextPost = collections.posts | getNextCollectionItem(page) %}

        <li><strong>&larr; 上一篇：</strong>
          {% if previousPost %}
            <a href="{{ previousPost.url }}" style="color: #0066cc; text-decoration: none;">{{ previousPost.data.title }}</a>
          {% else %}
            <span style="color: #999;">已經是最新一篇技術文章了</span>
          {% endif %}
        </li>
        <li><strong>&rarr; 下一篇：</strong>
          {% if nextPost %}
            <a href="{{ nextPost.url }}" style="color: #0066cc; text-decoration: none;">{{ nextPost.data.title }}</a>
          {% else %}
            <span style="color: #999;">敬請期待下一期技術專題更新</span>
          {% endif %}
        </li>
      </ul>
    </div>

    <footer class="post-content-footer">
      <div class="inner-navigation">
        <p><strong>站內導航閉環：</strong></p>
        <ul>
          <li>返回 <a href="/">DeepSeek 香港情報站首頁</a> 獲取每日最新動態。</li>
          <li>前往 <a href="/posts/">技術文章檔案庫</a> 檢索更多 AI 落地實踐。</li>
        </ul>
      </div>
    </footer>
  </article>

  <aside class="sidebar-area">
    <div class="sidebar-panel">
      <h3>📈 5篇最新更新指南</h3>
      <ul class="sidebar-list">
        {% for item in collections.posts | limit(5) %}
          <li><a href="{{ item.url }}" title="{{ item.data.title }}">{{ item.data.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</div>