---
layout: layouts/base.njk
---
<style>
  .layout-grid { display: grid; grid-template-columns: 17fr 7fr; gap: 40px; }
  @media (max-width: 768px) { .layout-grid { grid-template-columns: 1fr; } }

  .post-content-header h1 { font-size: 32px; color: #111; margin-top: 0; margin-bottom: 15px; line-height: 1.4; }
  .post-content-meta { font-size: 14px; color: #777; display: flex; gap: 20px; margin-bottom: 30px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
  .post-body-markdown { font-size: 16px; color: #222; line-height: 1.8; text-align: justify; }
  .post-body-markdown h2 { font-size: 24px; color: #0052cc; margin-top: 35px; border-left: 5px solid #0052cc; padding-left: 12px; }
  
  /* 上一篇下一篇組件 */
  .inner-navigation-box { display: flex; justify-content: space-between; gap: 20px; margin: 40px 0; padding-top: 25px; border-top: 1px solid #eee; }
  .nav-card { flex: 1; padding: 15px; border: 1px solid #e1e4e8; border-radius: 6px; background: #f9f9f9; text-decoration: none; min-width: 0; }
  .nav-card:hover { border-color: #0052cc; background: #fff; }
  .nav-card span { display: block; font-size: 12px; color: #888; margin-bottom: 4px; }
  .nav-card p { margin: 0; font-size: 15px; font-weight: bold; color: #222; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .sidebar-panel { border: 1px solid #e1e4e8; border-radius: 8px; padding: 20px; background: #fff; }
  .sidebar-panel h3 { margin-top: 0; font-size: 18px; border-left: 4px solid #0052cc; padding-left: 10px; margin-bottom: 15px; }
  .sidebar-list { list-style: none; padding: 0; margin: 0; }
  .sidebar-list li { padding: 8px 0; border-bottom: 1px dashed #eee; }
  .sidebar-list a { text-decoration: none; color: #333; font-size: 14px; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sidebar-list a:hover { color: #0052cc; }
</style>

<div class="layout-grid">
  <article class="post-content-wrapper">
    <header class="post-content-header">
      {# 🌟 智能保險鎖：只有當 AI 生成的正文裡不帶有 <h1> 時，外殼才渲染文章標題為 H1 #}
      {% if "<h1" not in content %}
        <h1>{{ title }}</h1> [cite: 7]
      {% endif %}
      <div class="post-content-meta">
        <span>發布日期：{{ date | dateFilter }}</span> [cite: 7, 8]
        <span>分類：DeepSeek 核心技術專題</span> [cite: 7]
        <span>讀者對象：香港開發者及企業決策層</span> [cite: 7]
      </div>
    </header>

    <section class="post-body-markdown">
      {{ content | safe }} [cite: 9]
    </section>
    
    <nav class="inner-navigation-box" aria-label="相鄰文章導航">
      {%- set previousPost = collections.posts | getPreviousCollectionItem(page) %}
      {%- set nextPost = collections.posts | getNextCollectionItem(page) %}

      <div style="flex: 1; min-width: 0;">
        {% if previousPost %}
          <a href="{{ previousPost.url }}" class="nav-card">
            <span>&larr; 上一篇技術指南</span>
            <p>{{ previousPost.data.title }}</p>
          </a>
        {% else %}
          <div class="nav-card" style="opacity: 0.6; cursor: not-allowed;">
            <span>&larr; 上一篇技術指南</span>
            <p>已是最新發布的第一篇專題</p>
          </div>
        {% endif %}
      </div>

      <div style="flex: 1; min-width: 0; text-align: right;">
        {% if nextPost %}
          <a href="{{ nextPost.url }}" class="nav-card">
            <span>下一篇技術指南 &rarr;</span>
            <p>{{ nextPost.data.title }}</p>
          </a>
        {% else %}
          <div class="nav-card" style="opacity: 0.6; cursor: not-allowed; text-align: right;">
            <span>下一篇技術指南 &rarr;</span>
            <p>敬請期待下一期技術專案更新</p>
          </div>
        {% endif %}
      </div>
    </nav>

    <footer class="post-content-footer" style="margin-top: 30px; padding-top: 15px; border-top: 1px dashed #eee;">
      <div class="inner-navigation">
        <p><strong>站內導航閉環：</strong></p> [cite: 9]
        <ul>
          <li>返回 <a href="/">DeepSeek 香港情報站首頁</a> 獲取每日最新動態。</li> [cite: 9]
          <li>前往 <a href="/posts/">技術文章檔案庫</a> 檢索更多 AI 落地實踐。</li> [cite: 9]
        </ul>
      </div>
    </footer>
  </article>

  <aside class="sidebar-area">
    <div class="sidebar-panel">
      <h3>📂 5篇最新更新技術指南</h3>
      <ul class="sidebar-list">
        {% for item in collections.posts | limit(5) %}
          <li><a href="{{ item.url }}" title="{{ item.data.title }}">{{ item.data.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</div>