---
layout: layouts/base.njk
---
<style>
    .post-container { display: grid; grid-template-columns: 1fr 300px; gap: 40px; margin: 40px 0; }
    @media (max-width: 800px) { .post-container { grid-template-columns: 1fr; } }
    .post-content h1 { font-size: 32px; color: var(--primary); border-bottom: 2px solid var(--bg); padding-bottom: 15px; }
    .sidebar-posts { background: var(--bg); padding: 20px; border-radius: 8px; height: fit-content; }
    .nav-links { display: flex; justify-content: space-between; margin-top: 50px; padding-top: 20px; border-top: 1px solid #eee; }
</style>

<div class="container post-container">
    <article class="post-content">
        {# 🌟 唯一 H1 文章标题 #}
        <h1>{{ title }}</h1>
        <p style="color: #999;">Tarikh: {{ date | dateFilter }}</p>
        <div class="body-text">{{ content | safe }}</div>

        <nav class="nav-links">
            {% set prev = collections.posts | getPreviousCollectionItem(page) %}
            {% set next = collections.posts | getNextCollectionItem(page) %}
            <div>{% if prev %} <a href="{{ prev.url }}">⬅️ {{ prev.data.title }}</a> {% endif %}</div>
            <div>{% if next %} <a href="{{ next.url }}">{{ next.data.title }} ➡️</a> {% endif %}</div>
        </nav>
    </article>

    <aside class="sidebar-posts">
        <h3>Berita Terkini</h3>
        <ul style="list-style: none; padding: 0;">
            {% for item in collections.posts | limit(5) %}
                <li style="margin-bottom: 15px; border-bottom: 1px dashed #ddd; padding-bottom: 5px;">
                    <a href="{{ item.url }}" style="text-decoration: none; color: var(--text); font-size: 14px;">{{ item.data.title }}</a>
                </li>
            {% endfor %}
        </ul>
    </aside>
</div>