<!DOCTYPE html>
<html lang="ms-MY">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | DeepSeek Malaysia Hub</title>
    <meta name="description" content="{{ description }}">
    <style>
        :root { --primary: #003366; --accent: #ffcc00; --bg: #f4f7f6; --text: #2c3e50; }
        body { font-family: 'Inter', sans-serif; line-height: 1.8; color: var(--text); background: #fff; margin: 0; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        header { border-bottom: 3px solid var(--primary); padding: 20px 0; background: #fff; position: sticky; top: 0; z-index: 100; }
        .header-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo a { text-decoration: none; color: var(--primary); font-weight: 900; font-size: 24px; }
        nav a { margin-left: 20px; text-decoration: none; color: var(--text); font-weight: 600; }
        nav a:hover { color: var(--primary); }
        footer { background: var(--primary); color: #fff; padding: 60px 0 20px; margin-top: 80px; }
        .friend-links { display: flex; flex-wrap: wrap; gap: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; margin-top: 30px; }
        .friend-links a { color: #ccc; text-decoration: none; font-size: 14px; }
        .friend-links a:hover { color: var(--accent); }
    </style>
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script>
    <script>LA.init({id:"3K7l95Zodr0uFrIN",ck:"3K7l95Zodr0uFrIN"})</script>
</head>
<body>
    <header>
        <div class="container header-flex">
            {# 🌟 解决 H1 冲突：首页用 H1，内页用 div #}
            {% if page.url == "/" %}
                <h1 class="logo" style="margin:0;"><a href="/">DEEPSEEK MALAYSIA</a></h1>
            {% else %}
                <div class="logo" style="font-weight:900; font-size:24px;"><a href="/">DEEPSEEK MALAYSIA</a></div>
            {% endif %}
            <nav>
                <a href="/">Utama</a>
                <a href="/posts/">Arkib</a>
            </nav>
        </div>
    </header>

    <main>{{ content | safe }}</main>

    <footer>
        <div class="container">
            <div style="text-align: center; margin-bottom: 40px;">
                <h3>Hab Teknologi DeepSeek Asia Tenggara</h3>
                <p>Menerajui revolusi AI untuk PKS di Malaysia.</p>
            </div>
            <div class="friend-links">
                <strong>Rangkaian Strategik:</strong>
                <a href="https://deepseek-chat.com" target="_blank">DeepSeek Sembang AI</a>
                <a href="https://hk-deepseek.com" target="_blank">DeepSeek Hong Kong Hub</a>
                <a href="https://deepseek-in.com" target="_blank">DeepSeek Global India</a>
                <a href="https://deepseek-1.com" target="_blank">DeepSeek Utama Satu</a>
                <a href="https://deepseek-my.com" target="_blank">DeepSeek Malaysia</a>
            </div>
            <p style="text-align: center; font-size: 12px; margin-top: 40px; color: #888;">&copy; 2026 DeepSeek-MY. Dikendalikan oleh 51.la Analytics.</p>
        </div>
    </footer>
</body>
</html>