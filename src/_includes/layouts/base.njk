<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | DeepSeek 香港非官方中文情報站</title> 
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="DeepSeek, DeepSeek香港, DeepSeek中文, AI大模型, 深度求索, DeepSeek教學, DeepSeek企業應用"> [cite: 2]
  
  <meta property="og:title" content="{{ title }} | DeepSeek 香港非官方中文情報站"> [cite: 2]
  <meta property="og:description" content="{{ description }}"> [cite: 2]
  <meta property="og:type" content="{{ 'article' if layout == 'layouts/post.njk' else 'website' }}"> [cite: 2]
  <meta property="og:locale" content="zh_HK"> [cite: 2]
  
  <link rel="stylesheet" href="/css/style.css"> [cite: 2]
  
  <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script> [cite: 2]
  <script>LA.init({id:"3K7l95Zodr0uFrIN",ck:"3K7l95Zodr0uFrIN"})</script> [cite: 2]
  <style>
    :root { --primary-color: #0052cc; --border-color: #e1e4e8; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.7; color: #333; margin: 0; padding: 0; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .site-header { border-bottom: 1px solid var(--border-color); padding: 20px 0; background: #fff; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; }
    .logo a { text-decoration: none; color: #111; font-weight: 800; font-size: 24px; }
    .logo div { font-weight: 800; font-size: 24px; }
    .site-nav ul { list-style: none; display: flex; gap: 25px; margin: 0; padding: 0; }
    .site-nav a { text-decoration: none; color: #555; font-weight: 500; }
    .site-nav a:hover, .site-nav a.active { color: var(--primary-color); }
    .site-footer { background: #f4f6f9; padding: 40px 0; border-top: 1px solid var(--border-color); margin-top: 60px; }
    .friend-links h3 { margin: 0 0 15px 0; font-size: 16px; color: #444; }
    .friend-links ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 20px; }
    .friend-links a { text-decoration: none; color: #666; font-size: 14px; }
    .friend-links a:hover { color: var(--primary-color); }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="container header-flex">
      {# 🌟 H1 衝突終極修復：僅在首頁渲染 H1 首頁Logo，內頁全自動降級為 div 容器，把神聖的 H1 名額單獨留給文章標題 #}
      {% if page.url == "/" %}
        <h1 class="logo" style="margin:0;"><a href="/">DeepSeek 香港情報站</a></h1> 
      {% else %}
        <div class="logo"><a href="/">DeepSeek 香港情報站</a></div> 
      {% endif %}
      <nav class="site-nav">
        <ul>
          <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>首頁</a></li> 
          <li><a href="/posts/" {% if page.url.startsWith('/posts/') %}class="active"{% endif %}>最新文章</a></li> 
        </ul>
      </nav>
    </div>
  </header>

  <main class="site-main container" style="margin-top: 30px; min-height: 600px;"> [cite: 4]
    {{ content | safe }} [cite: 4]
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="friend-links">
        <h3>友情鏈接：</h3> [cite: 4]
        <ul>
          <li><a href="https://deepseek-chat.com" target="_blank" rel="noopener" title="DeepSeek 線上聊天智能對話">DeepSeek 線上智能對話</a></li> [cite: 4]
          <li><a href="https://hk-deepseek.com" target="_blank" rel="noopener" title="DeepSeek 香港繁體技術社區">DeepSeek 香港技術社區</a></li> [cite: 4]
          <li><a href="https://deepseek-in.com" target="_blank" rel="noopener" title="DeepSeek 全球產業應用整合">DeepSeek 產業應用網</a></li> [cite: 4]
          <li><a href="https://deepseek-1.com" target="_blank" rel="noopener" title="DeepSeek 第一中文繁體教學門戶">DeepSeek 中文教學門戶</a></li> 
          <li><a href="https://deepseek-my.com" target="_blank" rel="noopener" title="DeepSeek 個人自動化高效方案">DeepSeek 高效方案中心</a></li> 
        </ul>
      </div>
      <div class="copyright" style="margin-top: 25px; color: #888; font-size: 14px; text-align: center;">
        <p>&copy; 2026 DeepSeek 香港非官方中文情報站。版權所有。本站內容專為香港及全球繁體用戶優化。</p> [cite: 6]
      </div>
    </div>
  </footer>

</body>
</html>