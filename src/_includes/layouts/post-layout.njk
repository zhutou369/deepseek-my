---
layout: layout.njk
---

<style>
    .post-header { margin-bottom: 30px; border-bottom: 1px solid #e2e8f0; padding-bottom: 20px; }
    .post-h1 { font-size: 26px; color: #0f172a; margin: 0 0 15px 0; line-height: 1.4; text-align: left; }
    .post-meta-data { font-size: 14px; color: #94a3b8; }
    
    /* 文章正文 SEO 排版強制優化 */
    .post-main-body { font-size: 16px; color: #334155; line-height: 1.9; text-align: justify; word-break: break-word; }
    .post-main-body h2 { font-size: 20px; color: #0f172a; margin-top: 35px; border-left: 4px solid #0052cc; padding-left: 10px; }
    .post-main-body h3 { font-size: 17px; color: #1e293b; margin-top: 25px; }
    .post-main-body p { margin-bottom: 20px; }
    .post-main-body img { max-width: 100% !important; height: auto !important; border-radius: 8px; margin: 20px 0; }
    
    /* 上一篇下一篇組件樣式 */
    .post-sibling-nav { display: flex; justify-content: space-between; gap: 20px; margin-top: 50px; padding-top: 25px; border-top: 1px solid #e2e8f0; }
    @media (max-width: 600px) { .post-sibling-nav { flex-direction: column; } }
    .nav-box { flex: 1; min-width: 0; }
    .nav-card { display: block; padding: 15px; border: 1px solid #e2e8f0; border-radius: 6px; background: #f8fafc; }
    .nav-card:hover { border-color: #0052cc; background: #fff; text-decoration: none; }
    .nav-label { font-size: 12px; color: #94a3b8; display: block; margin-bottom: 4px; text-transform: uppercase; }
    .nav-title { font-size: 14px; color: #334155; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
</style>

<div class="post-header">
    {# 🌟 核心SEO修復：內容頁全頁唯一的 h1 標籤，完美承接文章標題，杜絕權重污染 #}
    <h1 class="post-h1">{{ title }}</h1>
    <div class="post-meta-data">
        <span>📅 整理發布日期：{{ date | dateFilter }}</span>
        <span style="margin: 0 10px;">|</span>
        <span>🏷️ 欄目歸屬：<a href="/blog/">技術資訊大廳</a></span>
    </div>
</div>

{# 🌟 機器人生成的 Markdown 正文渲染槽 #}
<div class="post-main-body">
    {{ content | safe }}
</div>

{# 🌟 上一篇 / 下一篇 進階內鏈網絡 (利用 Eleventy 內置的 collections 關聯算力自動計算) #}
<nav class="post-sibling-nav">
    {% set previousPost = collections.posts | getPreviousCollectionItem(page) %}
    {% set nextPost = collections.posts | getNextCollectionItem(page) %}
    
    <div class="nav-box">
        {% if previousPost %}
            <a href="{{ previousPost.url }}" class="nav-card" title="{{ previousPost.data.title }}">
                <span class="nav-label">⬅️ 上一編文章</span>
                <span class="nav-title">{{ previousPost.data.title }}</span>
            </a>
        {% endif %}
    </div>
    
    <div class="nav-box" style="text-align: right;">
        {% if nextPost %}
            <a href="{{ nextPost.url }}" class="nav-card" title="{{ nextPost.data.title }}">
                <span class="nav-label">下一編文章 ➡️</span>
                <span class="nav-title">{{ nextPost.data.title }}</span>
            </a>
        {% endif %}
    </div>
</nav>