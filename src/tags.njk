---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/tags/{{ tag | tagSlug }}/index.html"
eleventyComputed:
  title: "Tags: {{ tag }} | DeepSeek Malaysia"
  description: "Artikel DeepSeek Malaysia berkaitan {{ tag }}, termasuk tutorial, FAQ, automasi dan nota teknikal praktikal."
---

{% set tagPosts = collections.posts | postsByTag(tag) %}

<div class="container" style="padding: 50px 20px;">
    <header style="margin-bottom: 35px;">
        <p style="margin: 0 0 6px; color: #999;">Tags</p>
        <h2 style="color: var(--primary); font-size: 32px;">{{ tag }}</h2>
        <p style="color: #667085;">Artikel yang berkaitan dengan topik ini dalam DeepSeek Malaysia Hub.</p>
    </header>

    {% for post in tagPosts %}
        <article style="padding: 22px 0; border-bottom: 1px solid #edf2f7;">
            <p style="margin: 0 0 6px; color: #999; font-size: 14px;">{{ post.date | dateFilter }}</p>
            <h3 style="margin: 0 0 8px;"><a href="{{ post.url }}" style="color: var(--primary); text-decoration: none;">{{ post.data.title }}</a></h3>
            <p style="margin: 0 0 10px; color: #667085;">{{ post.data.description }}</p>
            <a href="{{ post.url }}" style="font-weight: 700; color: var(--primary); text-decoration: none;">Baca artikel &rarr;</a>
        </article>
    {% else %}
        <p>Belum ada artikel untuk tag ini.</p>
    {% endfor %}

    <p style="margin-top: 30px;"><a href="/tags/">Kembali ke semua Tags</a></p>
</div>
